# SQLite
DATABASE_PATH=./data/vacancies.db

# Each comma-separated entry is searched as its OWN query (not joined).
# Use complete role phrases, not single broad words like "Junior".
KEYWORDS_JUNIOR=Junior Developer, Werkstudent Softwareentwicklung, Testautomatisierung, QA Engineer
KEYWORDS_PRAKTIKUM=Praktikum Softwareentwicklung, Praktikum Informatik
SEARCH_LOCATION=Leipzig
SEARCH_RADIUS_KM=150
INDEED_BASE_URL=https://de.indeed.com
STEPSTONE_BASE_URL=https://www.stepstone.de
LINKEDIN_BASE_URL=https://www.linkedin.com
LINKEDIN_DISTANCE_MILES=100
# Доступно: stepstone, linkedin, indeed, arbeitsagentur (API, без капчи)
# Indeed часто даёт 403 — рекомендуется stepstone,linkedin,arbeitsagentur + auth-сессии
SCRAPERS=stepstone,linkedin,arbeitsagentur
SEARCH_DELAY_MS=20000

# Загрузка полного текста вакансии со страницы объявления (медленнее, точнее)
FETCH_FULL_DESCRIPTION=true
DESCRIPTION_FETCH_DELAY_MS=3000
# Извлечение email из описания и mailto: на странице вакансии
EXTRACT_EMAIL=true

# Pagination — страниц на каждый поисковый URL (LinkedIn +25, Indeed +10, Stepstone +1)
SCRAPE_MAX_PAGES=3
SCRAPE_PAGE_DELAY_MS=5000
# Retries on transient navigation errors (timeouts / 5xx) per page
SCRAPE_MAX_RETRIES=2

# Browser — false = видимое окно (реже 403 от Cloudflare)
BROWSER_HEADLESS=true

# Saved browser sessions — npm run auth:linkedin / auth:indeed
# Файлы в ./data/ подхватываются автоматически, если существуют
LINKEDIN_STORAGE_STATE=./data/linkedin-auth.json
INDEED_STORAGE_STATE=./data/indeed-auth.json

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=plugin.vg.co@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=plugin.vg.co@gmail.com

# Applicant
APPLICANT_NAME=Vladyslav Plugin
# Optional letterhead details for the DIN 5008 cover letter PDF
APPLICANT_EMAIL=
APPLICANT_PHONE=
APPLICANT_LOCATION=Leipzig
# DCI graduation date used in the cover letter text
DCI_GRADUATION=Mai 2025

# LLM cover-letter generation (optional; falls back to template when off/unset)
LLM_ENABLED=false
# Provider: gemini (recommended free — 1500 req/day, key at aistudio.google.com)
#           | openai | anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=
# Leave empty to use the provider default (gemini-2.5-flash / gpt-4o-mini / claude-3-5-haiku-latest)
LLM_MODEL=
# Optional: OpenAI-compatible base URL for free providers
#   Groq:       https://api.groq.com/openai/v1   (LLM_PROVIDER=openai, LLM_MODEL=llama-3.3-70b-versatile)
#   OpenRouter: https://openrouter.ai/api/v1      (LLM_PROVIDER=openai, LLM_MODEL=<free-model>)
LLM_BASE_URL=
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=3000

# Test email recipient (for send:test script)
TEST_EMAIL_TO=plugin.vg.co@gmail.com
TEST_ATTACHMENT_PATH=./assets/Lebenslauf.pdf
# CV attached to real applications (defaults to TEST_ATTACHMENT_PATH if unset)
RESUME_PATH=./assets/Lebenslauf.pdf
# DCI-Abschlusszertifikat (3. PDF-Anhang); leer lassen = deaktiviert
DCI_CERTIFICATE_PATH=./assets/Zertifikat_Plugin, Vladyslav_FbW WD 24-E03.pdf

# Dispatcher — max applications per run
DISPATCH_LIMIT=15
# After this many failed attempts a vacancy gets status=failed (no same-day retry)
DISPATCH_MAX_RETRIES=3
# Require manual Telegram approval before sending (replies "да"/"нет")
DISPATCH_REQUIRE_APPROVAL=false
# How long to wait for the approval reply before declining (ms)
DISPATCH_APPROVAL_TIMEOUT_MS=600000
# Max applications to a single email domain per day (0 = unlimited)
DISPATCH_MAX_PER_DOMAIN_PER_DAY=1
# Comma-separated blocklist: company name substrings, email domains, or full addresses
DO_NOT_CONTACT=

# Pipeline notifications after pipeline:daily / cron
PIPELINE_NOTIFY_ENABLED=false
PIPELINE_NOTIFY_EMAIL=true
NOTIFY_EMAIL_TO=
# Telegram (optional): create bot via @BotFather, get chat id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Playwright — system Chromium (if bundled browser is unavailable)
CHROME_PATH=/usr/bin/google-chrome

# Tavily — поиск HR-email, если на странице вакансии нет контакта
# API key: https://app.tavily.com/
TAVILY_API_KEY=
# true = шаг Tavily в pipeline:daily и tavily:enrich
TAVILY_ENABLED=true
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
# HR-email lookups per run — main throughput limiter for new applications
TAVILY_MAX_LOOKUPS=25
TAVILY_MAX_QUERIES_PER_LOOKUP=2
TAVILY_EXTRACT_ENABLED=true
TAVILY_EXTRACT_DEPTH=basic
TAVILY_MAX_EXTRACT_URLS=3
TAVILY_LOOKUP_DELAY_MS=1500
# Re-attempt companies with no email found after this many days (0 = never re-attempt)
TAVILY_NEGATIVE_CACHE_TTL_DAYS=14
# Retries on transient Tavily API errors (5xx/network)
TAVILY_MAX_RETRIES=2

# Google Sheets sync (Service Account JSON + spreadsheet ID)
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_CREDENTIALS_PATH=./google-credentials.json
GOOGLE_SHEET_NAME=Sheet1
