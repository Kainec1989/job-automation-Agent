# SQLite
DATABASE_PATH=./data/vacancies.db

# Indeed search — comma-separated keyword lists
KEYWORDS_JUNIOR=Junior, Developer, Testautomatisierer
KEYWORDS_PRAKTIKUM=Praktikum, Praktikant
SEARCH_LOCATION=Leipzig
SEARCH_RADIUS_KM=150
INDEED_BASE_URL=https://de.indeed.com
STEPSTONE_BASE_URL=https://www.stepstone.de
LINKEDIN_BASE_URL=https://www.linkedin.com
LINKEDIN_DISTANCE_MILES=100
# Indeed часто даёт 403 — рекомендуется stepstone,linkedin + auth-сессии
SCRAPERS=stepstone,linkedin
SEARCH_DELAY_MS=20000

# Загрузка полного текста вакансии со страницы объявления (медленнее, точнее)
FETCH_FULL_DESCRIPTION=true
DESCRIPTION_FETCH_DELAY_MS=3000
# Извлечение email из описания и mailto: на странице вакансии
EXTRACT_EMAIL=true

# Browser — false = видимое окно (реже 403 от Cloudflare)
BROWSER_HEADLESS=true

# Saved browser sessions — npm run auth:linkedin / auth:indeed
# Файлы в ./data/ подхватываются автоматически, если существуют
LINKEDIN_STORAGE_STATE=./data/linkedin-auth.json
INDEED_STORAGE_STATE=./data/indeed-auth.json

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=plugin.vg.co@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=plugin.vg.co@gmail.com

# Applicant
APPLICANT_NAME=Vladyslav Plugin

# Test email recipient (for send:test script)
TEST_EMAIL_TO=plugin.vg.co@gmail.com
TEST_ATTACHMENT_PATH=./assets/Lebenslauf.pdf
# DCI-Abschlusszertifikat (3. PDF-Anhang); leer lassen = deaktiviert
DCI_CERTIFICATE_PATH=./assets/Zertifikat_Plugin, Vladyslav_FbW WD 24-E03.pdf

# Dispatcher — max applications per run
DISPATCH_LIMIT=10

# Playwright — system Chromium (if bundled browser is unavailable)
CHROME_PATH=/usr/bin/google-chrome

# Google Sheets sync (Service Account JSON + spreadsheet ID)
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_CREDENTIALS_PATH=./google-credentials.json
GOOGLE_SHEET_NAME=Sheet1
